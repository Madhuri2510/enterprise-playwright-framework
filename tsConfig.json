{
    "compilerOptions": {
      "target": "ESNext",
      "module": "commonjs",
      "moduleResolution": "node",
  
      "baseUrl": ".",
      "paths": {
        "@ai/*": ["ai/*"],
        "@utils/*": ["utils/*"],
        "@pages/*": ["pages/*"],
        "@api/*": ["api/*"]
      },
  
      "types": ["node"],
      "resolveJsonModule": true,
      "esModuleInterop": true,
  
      "strict": true,
      "skipLibCheck": true
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules"]
  }